      "id": "finding:PP-K8S-001:example-python-agent",
      "rule_id": "PP-K8S-001",
      "title": "Public workload can read Kubernetes Secret",
      "severity": "High",
      "summary": "Public endpoint kubernetes://prod/service/public-api routes to a workload whose ServiceAccount can read Secret metadata.",
      "path": [
        {
          "id": "node:public-endpoint",
          "kind": "PublicEndpoint",
          "name": "kubernetes://prod/service/public-api"
        },
        {
          "id": "node:workload",
          "kind": "Workload",
          "name": "kubernetes://prod/deployment/api"
        },
        {
          "id": "node:serviceaccount",
          "kind": "ServiceAccount",
          "name": "kubernetes://prod/serviceaccount/api"
        },
        {
          "id": "node:secret",
          "kind": "Secret",
          "name": "kubernetes://prod/secret/app-secret"
        }
      ],
      "source_references": [
        "service.yaml#document=1",
        "workload.yaml#document=1",
        "rbac.yaml#document=1"
      ],
      "baseline_status": "new",
      "remediation": {
        "id": "plan:example-python-agent-k8s",
        "finding_id": "finding:PP-K8S-001:example-python-agent",
        "rule_id": "PP-K8S-001",
        "summary": "Remediate Kubernetes Secret read access for the verified finding.",
        "options": [
          {
            "priority": 1,
            "action": "NarrowBindingSubject",
            "summary": "Remove the affected ServiceAccount from one multi-subject binding.",
            "rationale": "Removing only the affected ServiceAccount subject breaks the modeled read edge without deleting the binding for other subjects.",
            "requires_all_changes": false,
            "changes": [
              {
                "action": "NarrowBindingSubject",
                "target": {
                  "kind": "RoleBinding",
                  "namespace": "prod",
                  "name": "read-secrets"
                },
                "summary": "Remove only ServiceAccount prod/api from RoleBinding prod/read-secrets.",
                "source_reference": "rbac.yaml#document=1",
                "subject": "prod/api",
                "patch_supported": true
              }
            ]
          }
        ]
      }
    },
    {
